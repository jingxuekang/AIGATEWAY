    {
      "type": "stat",
      "title": "gateway-admin 堆内存使用率 (%)",
      "description": "gateway-admin 服务的 JVM 堆内存使用率",
      "gridPos": {
        "h": 8,
        "w": 2.66,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "max by (job) ((jvm_memory_used_bytes{area=\"heap\",job=\"gateway-admin\"} / jvm_memory_committed_bytes{area=\"heap\",job=\"gateway-admin\"}) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "value",
        "reduceOptions": {
          "values": false,
          "fields": "",
          "calcs": [
            "lastNotNull"
