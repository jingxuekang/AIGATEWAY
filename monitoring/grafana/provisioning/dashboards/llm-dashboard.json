{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "总请求数",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(llm_requests_total)", "legendFormat": "总请求数", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "成功率",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(llm_requests_total{status=\"success\"}) / sum(llm_requests_total) * 100", "legendFormat": "成功率", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] }, "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "type": "stat",
      "title": "Token 消耗总量",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "sum(llm_tokens_total{type=\"total\"})", "legendFormat": "总Token", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }, "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "P99 延迟",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(llm_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "P99", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2000 }, { "color": "red", "value": 5000 }] }, "unit": "ms" } }
    },
    {
      "type": "timeseries",
      "title": "每分钟请求量（按模型）",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "sum(rate(llm_requests_total[1m])) by (model)", "legendFormat": "{{model}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "延迟分位（P50 / P95 / P99）",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(llm_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(llm_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(llm_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "P99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Token 消耗速率（按类型）",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum(rate(llm_tokens_total{type=\"prompt\"}[5m])) by (model)", "legendFormat": "prompt - {{model}}", "refId": "A" },
        { "expr": "sum(rate(llm_tokens_total{type=\"completion\"}[5m])) by (model)", "legendFormat": "completion - {{model}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "错误率（按 Provider）",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "sum(rate(llm_requests_total{status=\"error\"}[5m])) by (provider) / sum(rate(llm_requests_total[5m])) by (provider) * 100", "legendFormat": "{{provider}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "type": "bargauge",
      "title": "各 Provider 请求占比",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{ "expr": "sum(llm_requests_total) by (provider)", "legendFormat": "{{provider}}", "refId": "A" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "type": "bargauge",
      "title": "各模型 Token 消耗 Top 10",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{ "expr": "topk(10, sum(llm_tokens_total{type=\"total\"}) by (model))", "legendFormat": "{{model}}", "refId": "A" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["llm", "aigateway"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AI Gateway - LLM 监控",
  "uid": "aigateway-llm",
  "version": 1
}
